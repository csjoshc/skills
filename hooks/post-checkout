#!/usr/bin/env bash
# Git post-checkout/post-merge hook: Auto-sync skills symlinks
# Install to .git/hooks/post-checkout and .git/hooks/post-merge
# This hook runs silently and only fixes broken symlinks.

SKILLS_SYNC="$HOME/.skills/sync.py"
LOG_FILE="$HOME/.skills/sync.log"

if [ -f "$SKILLS_SYNC" ]; then
    python3 "$SKILLS_SYNC" --audit --quiet >> "$LOG_FILE" 2>&1
    exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo "[skills-sync] Audit failed (exit $exit_code). Check $LOG_FILE" >&2
    fi
fi

exit 0
